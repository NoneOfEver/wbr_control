#include <dt-bindings/pinctrl/hpmicro-pinctrl-common.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	imu_test_gpios {
		compatible = "gpio-leds";

		imu_cs: imu_cs {
			gpios = <&gpioa 26 GPIO_ACTIVE_LOW>;
		};
	};
};

&pinctrl {
	/* 去掉 PA26 的 SPI CS 复用，只保留 MOSI/MISO/SCK
	 * 让 PA26 保持 GPIO 功能，由软件控制
	 */
	pinmux_spi2_nocs: pinmux_spi2_nocs {
		group0 {
			pinmux = <HPMICRO_PINMUX(HPMICRO_PIN(HPMICRO_PORTA, 27), IOC_TYPE_IOC, 0, 5)>,
				 <HPMICRO_PINMUX(HPMICRO_PIN(HPMICRO_PORTA, 31), IOC_TYPE_IOC, 0, 5)>,
				 <HPMICRO_PINMUX(HPMICRO_PIN(HPMICRO_PORTB,  0), IOC_TYPE_IOC, 0, 5)>;
			input-enable;
		};
	};

	pinmux_gpioa_imu_cs: pinmux_gpioa_imu_cs {
		group0 {
			pinmux = <HPMICRO_PINMUX(HPMICRO_PIN(HPMICRO_PORTA, 26), IOC_TYPE_IOC, 0, 0)>;
		};
	};
};

&spi2 {
	/* 覆盖 board 的 pinctrl，使用去掉 PA26 的版本 */
	pinctrl-0 = <&pinmux_spi2_nocs>;
	pinctrl-names = "default";
	/* 手动控制 CS，删除 board 默认 cs-gpios 避免 spi_context 自动管理 */
	/delete-property/ cs-gpios;
};

/* 确保 gpioa 已启用 */
&gpioa {
	status = "okay";
	pinctrl-0 = <&pinmux_gpioa_imu_cs>;
	pinctrl-names = "default";

	/* gpio-hog: CS is active-low, so logical output-low keeps PA26
	 * physically high during boot, matching the IMU SPI idle state.
	 */
	imu_cs_hog: imu_cs_hog {
		gpio-hog;
		gpios = <26 GPIO_ACTIVE_LOW>;
		output-low;
	};
};
